# SwayFX config with structured and documented keybindings.

# Global variables.
set $mod Mod4
set $terminal kitty
set $menu fuzzel
# Global UI font for Sway surfaces (title bars, bars, dialogs).
font pango:JetBrainsMono Nerd Font 10

# Keyboard layout: force French AZERTY.
input type:keyboard {
    xkb_layout fr
}

# Local machine overrides (untracked).
include ~/.config/sway/local.conf

# Core appearance and behavior.
focus_follows_mouse no
default_border pixel 2
# Rounded corners (SwayFX).
corner_radius 12
gaps inner 15
gaps outer 15

# Pointer/cursor defaults.
seat seat0 xcursor_theme Adwaita 24

# Default fallback background.
output * bg #1d1f21 solid_color

# Golden-ratio inspired floating defaults for dialogs/popups.
for_window [window_type="dialog"] floating enable, resize set width 62 ppt height 38 ppt, move position center
for_window [window_role="pop-up"] floating enable, resize set width 62 ppt height 38 ppt, move position center

# Keybindings: launch terminal.
bindsym $mod+Return exec $terminal

# Keybindings: launcher.
bindsym $mod+space exec $menu

# Keybindings: focus windows with arrows.
bindsym $mod+Left focus left
bindsym $mod+Right focus right
bindsym $mod+Up focus up
bindsym $mod+Down focus down

# Keybindings: move windows with Shift + arrows.
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Right move right
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Down move down

# Keybindings: workspace switch with top number row (layout-independent keycodes).
bindcode $mod+10 workspace number 1
bindcode $mod+11 workspace number 2
bindcode $mod+12 workspace number 3
bindcode $mod+13 workspace number 4
bindcode $mod+14 workspace number 5
bindcode $mod+15 workspace number 6
bindcode $mod+16 workspace number 7
bindcode $mod+17 workspace number 8
bindcode $mod+18 workspace number 9

# Keybindings: move focused window to top number row workspace.
bindcode $mod+Shift+10 move container to workspace number 1
bindcode $mod+Shift+11 move container to workspace number 2
bindcode $mod+Shift+12 move container to workspace number 3
bindcode $mod+Shift+13 move container to workspace number 4
bindcode $mod+Shift+14 move container to workspace number 5
bindcode $mod+Shift+15 move container to workspace number 6
bindcode $mod+Shift+16 move container to workspace number 7
bindcode $mod+Shift+17 move container to workspace number 8
bindcode $mod+Shift+18 move container to workspace number 9

# Keybindings: workspace switch with numeric keypad.
bindsym $mod+KP_1 workspace number 1
bindsym $mod+KP_2 workspace number 2
bindsym $mod+KP_3 workspace number 3
bindsym $mod+KP_4 workspace number 4
bindsym $mod+KP_5 workspace number 5
bindsym $mod+KP_6 workspace number 6
bindsym $mod+KP_7 workspace number 7
bindsym $mod+KP_8 workspace number 8
bindsym $mod+KP_9 workspace number 9

# Keybindings: move focused window to keypad workspace.
bindsym $mod+Shift+KP_1 move container to workspace number 1
bindsym $mod+Shift+KP_2 move container to workspace number 2
bindsym $mod+Shift+KP_3 move container to workspace number 3
bindsym $mod+Shift+KP_4 move container to workspace number 4
bindsym $mod+Shift+KP_5 move container to workspace number 5
bindsym $mod+Shift+KP_6 move container to workspace number 6
bindsym $mod+Shift+KP_7 move container to workspace number 7
bindsym $mod+Shift+KP_8 move container to workspace number 8
bindsym $mod+Shift+KP_9 move container to workspace number 9

# Keybindings: cycle focus like simple Alt+Tab behavior.
bindsym Alt+Tab focus next
bindsym Alt+Shift+Tab focus prev

# Keybindings: lock session.
# If swaylock-effects is installed, adjust lock visuals in local.conf.
bindsym $mod+l exec swaylock -f -c 000000

# Keybindings: power menu.
bindsym Ctrl+Alt+Delete exec ~/.config/scripts/session_menu.sh

# Keybindings: multimedia volume control.
bindsym XF86AudioRaiseVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+
bindsym XF86AudioLowerVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindsym XF86AudioMute exec wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle

# Keybindings: brightness control.
bindsym Alt+XF86AudioRaiseVolume exec brightnessctl set +10%
bindsym Alt+XF86AudioLowerVolume exec brightnessctl set 10%-

# Keybindings: reload config.
bindsym $mod+Shift+r reload

# Keybindings: restart Sway session.
bindsym $mod+Shift+e exec "swaymsg exit"

# Keybindings: screenshot selected region to ~/Pictures.
bindsym Print exec sh -c 'mkdir -p "$HOME/Pictures"; grim -g "$(slurp)" "$HOME/Pictures/screenshot-$(date +%F-%T).png"'

# Keybindings: choose wallpaper with fuzzy picker.
bindsym $mod+Shift+w exec ~/.config/scripts/wallpaper_picker.sh

# Keybindings: close focused window.
bindsym $mod+q kill

# Keybindings: toggle floating mode.
bindsym $mod+Shift+space floating toggle

# Autostart components.
exec_always --no-startup-id ~/.config/scripts/swayfx_effects_apply.sh
exec_always --no-startup-id swaync
exec_always --no-startup-id ~/.config/scripts/wallpaper_start.sh
exec_always --no-startup-id waybar
exec_always --no-startup-id udiskie --tray
